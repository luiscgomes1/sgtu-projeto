PORT=4000

# Supabase (opcional — usado apenas se storage for Supabase)
SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=

# Banco de dados (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT
JWT_SECRET=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
MOTORISTAS_GROUP_ID=
API_URL=http://localhost:4000/api
API_KEY=
BOT_API_KEY=
BOT_JWT_EXPIRES_IN=1h

# Frontend
FRONTEND_URL=http://localhost:5173

# Storage
STORAGE_BUCKET=sgtu-files
WEB_VIEW_TOKEN=

# Horários QR Code
QR_CODE_IDA_INICIO=16:50
QR_CODE_IDA_FIM=18:00
QR_CODE_VOLTA_INICIO=21:00
QR_CODE_VOLTA_FIM=23:00

# Geral
TZ=America/Sao_Paulo
NODE_ENV=development
BOT_CLIENT_HEADER=X-Bot-Client
